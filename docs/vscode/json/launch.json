{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(lldb) Debug current Pascal file",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/${fileBasenameNoExtension}",
            "args": ["-d", "-f", "${workspaceFolder}/tools/hmake/samples/makefile", "test"],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "preLaunchTask": "${defaultBuildTask}"
        },
        {
            "type": "gdb",
            "request": "launch",
            "name": "(gdb) Debug current Pascal file",
            "target": "${workspaceFolder}/build/${fileBasenameNoExtension}",
            "arguments": "-d -f ${workspaceFolder}/tools/hmake/samples/makefile test",
            "stopAtEntry": false,
            "cwd": "${workspaceRoot}",
            "valuesFormatting": "parseText"
        }
   ]
}